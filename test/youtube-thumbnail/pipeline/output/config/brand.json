    "target_audience": "AI 활용에 관심 있는 일반인~중급자 (20-40대)",
    "tone": "bright_energetic",
    "visual_direction": "screen_demo"
  },
  "colors": {
    "primary": {
      "name": "Electric Blue",
      "hex": "#2D7FF9",
      "rgb": [45, 127, 249],
      "usage": "메인 강조색, 배지 배경"
    },
    "secondary": {
      "name": "Vivid Yellow",
      "hex": "#FFD600",
      "rgb": [255, 214, 0],
      "usage": "텍스트 하이라이트, 주목 유도"
    },
    "dark": {
      "name": "Deep Navy",
      "hex": "#0D1B2A",
      "rgb": [13, 27, 42],
      "usage": "텍스트 외곽선, 오버레이 배경"
    }
  },
  "fonts": {
    "primary": {
      "family": "Pretendard",
      "weight": 800,
      "weight_name": "ExtraBold",
      "license": "OFL",
      "usage": "메인 텍스트"
    },
    "secondary": {
      "family": "Pretendard",
      "weight": 700,
      "weight_name": "Bold",
      "license": "OFL",
      "usage": "보조/영문 텍스트"
    }
  },
  "text_style": {
    "max_words": 5,
    "max_chars_kr": 10,
    "font_size_range": [60, 90],
    "stroke_width": [3, 5],
    "stroke_color": "#0D1B2A",
    "shadow": {
      "offset": [2, 2],
      "blur": 4,
      "color": "#00000080"
    },
    "color_combos": {
      "main": { "text": "#FFD600", "stroke": "#0D1B2A" },
      "sub": { "text": "#FFFFFF", "stroke": "#0D1B2A" },
      "badge": { "bg": "#2D7FF9", "text": "#FFFFFF" }
    }
  },
  "layout": {
    "canvas": { "width": 1280, "height": 720 },
    "safe_zone": { "top": 0, "right": 20, "bottom": 60, "left": 20 },
    "types": {
      "screen_demo": {
        "description": "AI 시연 화면 좌측 60% + 텍스트 우측 40%",
        "screen_area": { "x": 0, "y": 0, "w": 768, "h": 720 },
        "text_area": { "x": 780, "y": 100, "w": 480, "h": 560 }
      },
      "full_bg_center_text": {
        "description": "AI 생성 풀 배경 + 중앙 텍스트",
        "text_area": { "x": 200, "y": 150, "w": 880, "h": 420 }
      },
      "character_text": {
        "description": "캐릭터/웹캠 좌측 40% + 텍스트 우측 60% (추후)",
        "character_area": { "x": 0, "y": 0, "w": 512, "h": 720 },
        "text_area": { "x": 530, "y": 100, "w": 730, "h": 560 }
      }
    },
    "default_type": "screen_demo"
  },
  "overlay": {
    "color": "#0D1B2A",
    "opacity_range": [0.4, 0.6]
  }
}
